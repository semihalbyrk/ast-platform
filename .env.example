# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ast_db
DB_USER=ast_user
DB_PASSWORD=ast_password

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=ast_minio
MINIO_SECRET_KEY=ast_minio_secret
MINIO_BUCKET=ast-documents
MINIO_USE_SSL=false

# JWT
JWT_SECRET=ast-dev-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# App
APP_PORT=3000
NODE_ENV=development
APP_CORS_ORIGIN=http://localhost:10099
